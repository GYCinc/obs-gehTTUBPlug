#!/bin/bash
# preply — One command: OBS + captions + auto class link + Chrome
set -e

DIR="$(cd "$(dirname "$0")" && pwd)"
OBS_PID=""
CONTROLLER_PID=""
CLASS_LINK=""

cleanup() {
    echo ""
    if [ -n "$CONTROLLER_PID" ] && kill -0 "$CONTROLLER_PID" 2>/dev/null; then
        kill "$CONTROLLER_PID" 2>/dev/null
        wait "$CONTROLLER_PID" 2>/dev/null
        echo "OBS controller stopped."
    fi
    if [ -n "$OBS_PID" ] && kill -0 "$OBS_PID" 2>/dev/null; then
        kill "$OBS_PID" 2>/dev/null
        wait "$OBS_PID" 2>/dev/null
        echo "OBS closed."
    fi
    echo "Done."
}

trap cleanup EXIT INT TERM

echo "=== preply: fetching next class ==="
source "$HOME/.bashrc" 2>/dev/null

# Step 1: Try Cal.com
CLASS_LINK=$(curl -s -H "Authorization: Bearer $CAL_API_KEY" \
    "https://api.cal.com/v2/bookings?status=upcoming&take=1" 2>/dev/null | \
    python3 -c "
import json,sys
data = json.load(sys.stdin)
bookings = data.get('data', {}).get('bookings', [])
if bookings:
    b = bookings[0]
    loc = b.get('location', '') or b.get('metadata', {}).get('videoCallUrl', '')
    print(loc) if loc else print('')
else:
    print('')
" 2>/dev/null)

# Step 2: Fallback to Google Calendar ICS
if [ -z "$CLASS_LINK" ] && [ -n "$GCAL_ICS_URL" ]; then
    echo "  Cal.com empty, checking Google Calendar..."
    CLASS_LINK=$(curl -sL "$GCAL_ICS_URL" 2>/dev/null | \
        python3 -c "
import sys, re
from datetime import datetime, timezone
ics = sys.stdin.read()
events = []
for match in re.finditer(r'BEGIN:VEVENT(.*?)END:VEVENT', ics, re.DOTALL):
    e = match.group(1)
    dtstart = re.search(r'DTSTART[^:]*:(\d{8}T\d{6}Z?)', e)
    desc = re.search(r'DESCRIPTION:(.*?)(?:\n|$)', e)
    summary = re.search(r'SUMMARY:(.*?)(?:\n|$)', e)
    loc = re.search(r'LOCATION:(.*?)(?:\n|$)', e)
    if dtstart:
        dt = dtstart.group(1)
        events.append({
            'start': datetime.strptime(dt[:15], '%Y%m%dT%H%M%S').replace(tzinfo=timezone.utc),
            'desc': (desc.group(1) if desc else ''),
            'summary': (summary.group(1) if summary else ''),
            'location': (loc.group(1) if loc else ''),
        })
now = datetime.now(timezone.utc)
future = [e for e in events if e['start'] > now]
if future:
    next_ev = sorted(future, key=lambda e: e['start'])[0]
    # Look for preply link in description and location
    combined = next_ev['description'] + ' ' + next_ev['location']
    link = re.search(r'https?://preply\.com/\S+', combined)
    print(link.group(0) if link else '')
" 2>/dev/null)
fi

# Step 3: Default fallback
CLASS_LINK="${CLASS_LINK:-https://preply.com}"
echo "  Class link: $CLASS_LINK"

echo "=== Launching OBS ==="
flatpak run com.obsproject.Studio --disable-shutdown-check &
OBS_PID=$!
sleep 3

echo "=== Starting OBS controller (captions + virtual camera + dual audio) ==="
source "$HOME/.bashrc" 2>/dev/null
"$DIR/.venv/bin/python3" "$DIR/obs-controller.py" &
CONTROLLER_PID=$!
sleep 2

echo "=== Launching Chrome → $CLASS_LINK ==="
flatpak run com.google.Chrome \
    --force-webrtc-ip-handling-policy=disable_non_proxied_udp \
    --webrtc-ip-handling-policy=disable_non_proxied_udp \
    --enforce-webrtc-ip-permission-check \
    --disable-background-networking \
    --disable-sync \
    --disable-geolocation \
    --window-size=1920,1080 \
    --no-first-run \
    --no-default-browser-check \
    --disable-extensions \
    --disable-background-mode \
    --disable-component-update \
    "$CLASS_LINK" &
CHROME_PID=$!

wait $CHROME_PID 2>/dev/null
