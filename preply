#!/bin/bash
DIR="$(cd "$(dirname "$0")" && pwd)"
OBS_PID=""; CTRL_PID=""
cleanup() { [ -n "$CTRL_PID" ] && kill "$CTRL_PID" 2>/dev/null
            [ -n "$OBS_PID" ] && kill "$OBS_PID" 2>/dev/null; }
trap cleanup EXIT
flatpak run com.obsproject.Studio --disable-shutdown-check & OBS_PID=$!
sleep 3
"$DIR/.venv/bin/python3" "$DIR/obs-controller.py" & CTRL_PID=$!
wait $CTRL_PID
